# Copy to .env and fill in values before running docker compose up

SECRET_KEY=change-me-use-a-long-random-string
DEBUG=False
ALLOWED_HOSTS=172.16.232.103,localhost

# Used by docker-compose.yml to build the DATABASE_URL for each service
DB_PASSWORD=change-me-strong-password

# These are set automatically by docker-compose from DB_PASSWORD / redis service name
# DATABASE_URL=postgres://hospital:<DB_PASSWORD>@db:5432/hospital_copilot
# REDIS_URL=redis://redis:6379/0

ANTHROPIC_API_KEY=

LOG_LEVEL=INFO

# Optional — TLS / Sentry
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
SENTRY_DSN=
